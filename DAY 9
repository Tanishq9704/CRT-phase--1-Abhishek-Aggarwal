//problem -- 1 
// Function overriding

#include <iostream>
using namespace std;

class kitchenAppliances{
    
    public:
  virtual void turnOn(){
        cout << " appliances are starting up....." << "\n";
    }
    public:
 virtual void work(){
     }
};

class toaster : public kitchenAppliances{
   void work() override {
       cout << " toast is heating up...";
   }
       
};

class fan : public kitchenAppliances{
    public:
     void turnOn() override{
        cout << "fan blades are moving slowly..." << "\n";
         }
         public:
    void work()override {
        cout << "fan is giving cool air" << "\n";
    }
    
};


int main(){
    kitchenAppliances* kitchenApp;
    fan myfan;
    kitchenApp = &myfan;
    kitchenApp -> turnOn();
    kitchenApp -> turnOn();
    
    toaster mytoast;
    kitchenApp = &mytoast;
    kitchenApp -> turnOn();
    kitchenApp -> work();
    
    return 0;
}

