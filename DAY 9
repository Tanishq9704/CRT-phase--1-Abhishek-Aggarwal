// problem 2
// Constructor Overloading
// values are passed within the object

#include <iostream>
using namespace std;

class rectangle{
  public:
  int length;
  int width;
  
  rectangle(){
      length = 1;
      width = 1;
      
  }
  
  rectangle(int side){
      length = side;
      width = side;
  }
  
  rectangle(int side1, int side2){
      length = side1;
      width = side2;
  }
  
  void showarea(){
     cout << length * width << "\n";
  }
  
};


int main(){
    rectangle r1;
    rectangle r2(5);
    rectangle r3(5,4);
    
    r1.showarea();
    r2.showarea();
    r3.showarea();
    return 0;
}

