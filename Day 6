// practice problem -- 5
// Smart AC Remote // Function Overloading // default arguments

#include <iostream>
using namespace std;

void setTemperature(int temp = 22){
    cout << "Temperature set to " << temp << "\n" ;
}

void setTemperature(double temp){
    cout << "Temperature set to " << temp <<  "\n" ;
}

void setTemperature(string mode){
    if(mode == "ECO"){
            cout << "Temperature set to 24" << "\n" ;
    }else if(mode == "TURBO"){
         cout << "Temperature set to 16" << "\n" ;
    }
    
}


int main(){
   setTemperature(); // default value -- 22
   setTemperature(20.5); // manually setting the Temperature
   setTemperature("ECO"); // set Temperature to 24;
   setTemperature("TURBO"); // set Temperature to 18
}
