// problem 4
// coffee price

#include <iostream>
using namespace std;

int chocolatecoffee(int c){
    return c*30;
}

int coldcoffee(int d){
    return d*60;
}

int hazelnutcoffee(int e){
    return e*100;
}

int main(){
   
      int choice;
    cout << "1. chocolate coffee\n2. cold coffee\n3. hazelnut coffee\n";
    cout << "Enter your choice: ";
    cin >> choice;
    int n; 
    cin >> n ;

    switch (choice) {
        case 1:
            cout << chocolatecoffee(n) << endl;
            break;
        case 2:
            cout << coldcoffee(n) << endl;
            break;
        case 3:
            cout << hazelnutcoffee(n) << endl;
            break;
        default:
            cout << "Invalid choice! Please try again." << endl;
    }
    return 0;
}

