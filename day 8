//Problem 5
//hybrid inheritence using virtual base class
#include <iostream>
using namespace std;

class grandparent{
  public:
  void health(){
    cout << "grand parent health is fine""\n";
}
};

class parent1 : virtual public grandparent {
    public:
    // no logic
    };


class parent2 : virtual public grandparent {
    public:
    // no logic
};

class child : public parent1, public parent2{
    // no logic
};

int main(){
   child obj1;
   obj1.health();
}
