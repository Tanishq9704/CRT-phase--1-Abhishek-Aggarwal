//problem 1
// inheritence
#include <iostream>
using namespace std;

class vehicle{
    public:
    void engine(){
        cout << "vehicle starts" << "\n";
    }
}; 

class car : public vehicle {
    public:
    void drive(){
    cout << "car is running" << "\n" ;  
    }
};

int main()
{
   car obj1;
   obj1.drive();
   obj1.engine();

    return 0;
}

