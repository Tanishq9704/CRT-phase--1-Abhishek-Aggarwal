  //Problem 2
//multilevel inheritence
#include <iostream>
using namespace std;

class vehicle{
    public:
    void engine(){
        cout << "vehicle starts" << "\n";
    }
}; 

class car : public vehicle {
    public:
    void drive(){
    cout << "car is running" << "\n" ;  
    }
};

class speedometer : public car {
    public:
    void speed(){
        cout << "car is running at 60km/hr";
    }
};

int main()
{
   speedometer obj1;
   obj1.drive();
   obj1.engine();
   obj1.speed();

    return 0;
}

