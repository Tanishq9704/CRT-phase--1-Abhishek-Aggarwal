//problem 3
//pillar of OOPs
// Encapsulation - it means we're binding the data into single unit (functions , data , variables , methods)
//into a single unit called class and making some restrictions on this class member.
// data Security
// controlled access over my data
// validation before acess

#include<iostream>
using namespace std;

class bankaccountant{
    private:
    int balance;
    
    public:
    void setbalance(int amount){
    if(amount >= 0){
        balance = amount;
        
    }else {
        cout << "Enter a valid Number...";
    }
    }
    
    public:
    int getbalance(){
        return balance;
    }
};

int main(){
    bankaccountant obj1;
    obj1.setbalance(5000);
    obj1.getbalance();
    cout << obj1.getbalance();
}

